# ─── Server Ports ───────────────────────────────────────────────
GATEWAY_PORT=3000
INGESTION_PORT=3001
TWIN_PORT=3002
AGENT_PORT=3003
DECISION_PORT=3004

# ─── Databases ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/aion_control_tower
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Python AI Services ─────────────────────────────────────────
ANOMALY_SERVICE_URL=http://localhost:8001
FORECASTING_SERVICE_URL=http://localhost:8002
MAINTENANCE_SERVICE_URL=http://localhost:8003

# ─── Kafka (or simulated event bus) ─────────────────────────────
KAFKA_BROKERS=localhost:9092
USE_KAFKA=false

# ─── Internal Service URLs ───────────────────────────────────────
INGESTION_SERVICE_URL=http://localhost:3001
TWIN_SERVICE_URL=http://localhost:3002
DECISION_SERVICE_URL=http://localhost:3004

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
